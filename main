      <button class="tab" onclick="switchTab('anime','completed')">COMPLETED</button>
      <button class="tab" onclick="switchTab('anime','next')">WATCHING NEXT</button>
    </div>

    <div id="anime-current" class="list-section visible">
      <button class="add-item-btn" onclick="toggleForm('anime-current-form')">+ ADD ANIME</button>
      <p class="section-help">Hover over items to <span>change status</span> or delete · Drag & drop to move between sections</p>
      <div id="anime-current-form" class="add-form">
        <input type="text" id="anime-current-name" placeholder="Anime Title">
        <input type="text" id="anime-current-meta" placeholder="Genre · Details">
        <input type="text" id="anime-current-url" placeholder="URL (optional)">
        <div class="form-actions">
          <button class="form-btn save" onclick="addItem('anime', 'current')">SAVE</button>
          <button class="form-btn cancel" onclick="toggleForm('anime-current-form')">CANCEL</button>
        </div>
      </div>
      <div class="list-grid" id="anime-current-list"></div>
    </div>

    <div id="anime-completed" class="list-section">
      <button class="add-item-btn" onclick="toggleForm('anime-completed-form')">+ ADD ANIME</button>
      <p class="section-help">Hover to <span>change status</span> or delete</p>
      <div id="anime-completed-form" class="add-form">
        <input type="text" id="anime-completed-name" placeholder="Anime Title">
        <input type="text" id="anime-completed-meta" placeholder="Genre · Details">
        <input type="text" id="anime-completed-url" placeholder="URL (optional)">
        <div class="form-actions">
          <button class="form-btn save" onclick="addItem('anime', 'completed')">SAVE</button>
          <button class="form-btn cancel" onclick="toggleForm('anime-completed-form')">CANCEL</button>
        </div>
      </div>
      <div class="list-grid" id="anime-completed-list"></div>
    </div>

    <div id="anime-next" class="list-section">
      <button class="add-item-btn" onclick="toggleForm('anime-next-form')">+ ADD ANIME</button>
      <p class="section-help">Hover to <span>change status</span> or delete</p>
      <div id="anime-next-form" class="add-form">
        <input type="text" id="anime-next-name" placeholder="Anime Title">
        <input type="text" id="anime-next-meta" placeholder="Genre · Details">
        <input type="text" id="anime-next-url" placeholder="URL (optional)">
        <div class="form-actions">
          <button class="form-btn save" onclick="addItem('anime', 'next')">SAVE</button>
          <button class="form-btn cancel" onclick="toggleForm('anime-next-form')">CANCEL</button>
        </div>
      </div>
      <div class="list-grid" id="anime-next-list"></div>
    </div>
  </div>

</main>

<footer>
  <span>TFT</span> ONLY — send an invite and i'll join &nbsp;·&nbsp; everything else, don't bother
</footer>

<script>
// ── AUTHENTICATION ──
// To change your password, edit the line below:
const DEFAULT_PASSWORD = 'changeme123'; // Change this to your own password!

function checkAuth() {
  const isLoggedIn = localStorage.getItem('isLoggedIn') === 'true';
  if (isLoggedIn) {
    document.body.classList.add('edit-mode');
    document.getElementById('auth-btn').textContent = 'LOGOUT';
    document.getElementById('auth-btn').classList.add('logged-in');
  } else {
    document.body.classList.remove('edit-mode');
    document.getElementById('auth-btn').textContent = 'LOGIN';
    document.getElementById('auth-btn').classList.remove('logged-in');
  }
  return isLoggedIn;
}

function toggleAuth() {
  const isLoggedIn = localStorage.getItem('isLoggedIn') === 'true';
  if (isLoggedIn) {
    logout();
  } else {
    document.getElementById('auth-modal').classList.add('visible');
    document.getElementById('auth-password').focus();
    document.getElementById('auth-error').classList.remove('visible');
  }
}

function login() {
  const password = document.getElementById('auth-password').value;
  const savedPassword = localStorage.getItem('adminPassword') || DEFAULT_PASSWORD;
  
  if (password === savedPassword) {
    localStorage.setItem('isLoggedIn', 'true');
    document.getElementById('auth-modal').classList.remove('visible');
    document.getElementById('auth-password').value = '';
    checkAuth();
  } else {
    document.getElementById('auth-error').classList.add('visible');
  }
}

function logout() {
  localStorage.setItem('isLoggedIn', 'false');
  checkAuth();
}

// Close modal on Escape key
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') {
    document.getElementById('auth-modal').classList.remove('visible');
  }
  if (e.key === 'Enter' && document.getElementById('auth-modal').classList.contains('visible')) {
    login();
  }
});

// Close modal when clicking outside
document.getElementById('auth-modal').addEventListener('click', (e) => {
  if (e.target.id === 'auth-modal') {
    document.getElementById('auth-modal').classList.remove('visible');
  }
});

const initialData = {
  games: {
    current: [
      { name: 'Teamfight Tactics', meta: 'Strategy · Set 13', url: '' },
      { name: 'Elden Ring', meta: 'Action RPG · NG+', url: '' },
      { name: 'Honkai: Star Rail', meta: 'Turn-based RPG · Endgame', url: '' }
    ],
    completed: [
      { name: 'Hollow Knight', meta: 'Metroidvania · 100%', url: '' },
      { name: 'Cyberpunk 2077', meta: 'Open World RPG · All Endings', url: '' },
      { name: 'Persona 5 Royal', meta: 'JRPG · True Ending', url: '' },
      { name: 'God of War Ragnarök', meta: 'Action-Adventure · Platinum', url: '' },
      { name: 'Hades', meta: 'Roguelike · Heat 32', url: '' },
      { name: 'Sekiro: Shadows Die Twice', meta: 'Action RPG · All Bosses', url: '' }
    ],
    next: [
      { name: 'Black Myth: Wukong', meta: 'Action RPG · In Queue', url: '' },
      { name: 'Metaphor: ReFantazio', meta: 'JRPG · In Queue', url: '' },
      { name: 'Monster Hunter Wilds', meta: 'Action RPG · In Queue', url: '' }
    ]
  },
  anime: {
    current: [
      { name: 'Dandadan', meta: 'Action · Supernatural · Season 1', url: '' },
      { name: 'Solo Leveling Season 2', meta: 'Action · Fantasy · Airing', url: '' },
      { name: 'Demon Slayer', meta: 'Action · Infinity Fortress Arc', url: '' }
    ],
    completed: [
      { name: 'Attack on Titan', meta: 'Action · Drama · Completed', url: '' },
      { name: 'Fullmetal Alchemist: Brotherhood', meta: 'Action · Fantasy · Classic', url: '' },
      { name: 'Jujutsu Kaisen', meta: 'Action · Dark Fantasy', url: '' },
      { name: 'Vinland Saga', meta: 'Historical · Drama · S1 & S2', url: '' },
      { name: 'Hunter x Hunter', meta: 'Adventure · Shonen · 148 eps', url: '' },
      { name: 'Cowboy Bebop', meta: 'Sci-Fi · Space · Classic', url: '' },
      { name: 'One Punch Man', meta: 'Action · Comedy · S1 & S2', url: '' },
      { name: 'Chainsaw Man', meta: 'Dark Fantasy · Action · S1', url: '' }
    ],
    next: [
      { name: 'Berserk', meta: 'Dark Fantasy · On Deck', url: '' },
      { name: 'Neon Genesis Evangelion', meta: 'Mecha · Psychological · On Deck', url: '' },
      { name: 'Frieren: Beyond Journey\'s End', meta: 'Fantasy · Adventure · On Deck', url: '' },
      { name: 'Blue Lock', meta: 'Sports · Drama · On Deck', url: '' }
    ]
  }
};

let data = JSON.parse(localStorage.getItem('playerStatusData')) || initialData;

function saveData() {
  localStorage.setItem('playerStatusData', JSON.stringify(data));
}

function switchTab(section, tab) {
  document.querySelectorAll(`#${section}-tabs .tab`).forEach(t => t.classList.remove('active'));
  event.target.classList.add('active');
  document.querySelectorAll(`[id^="${section}-"]`).forEach(el => el.classList.remove('visible'));
  document.getElementById(`${section}-${tab}`).classList.add('visible');
}

function toggleForm(formId) {
  const form = document.getElementById(formId);
  form.classList.toggle('visible');
  if (form.classList.contains('visible')) {
    form.querySelector('input').focus();
  }
}

function addItem(section, status) {
  const name = document.getElementById(`${section}-${status}-name`).value.trim();
  const meta = document.getElementById(`${section}-${status}-meta`).value.trim();
  const url = document.getElementById(`${section}-${status}-url`).value.trim();
  
  if (!name) return;
  
  data[section][status].push({ name, meta, url });
  saveData();
  renderList(section, status);
  
  document.getElementById(`${section}-${status}-name`).value = '';
  document.getElementById(`${section}-${status}-meta`).value = '';
  document.getElementById(`${section}-${status}-url`).value = '';
  toggleForm(`${section}-${status}-form`);
}

function deleteItem(section, status, index) {
  if (confirm('Delete this item?')) {
    data[section][status].splice(index, 1);
    saveData();
    renderList(section, status);
  }
}

function changeStatus(section, fromStatus, index, toStatus) {
  if (fromStatus === toStatus) return;
  
  const item = data[section][fromStatus][index];
  data[section][fromStatus].splice(index, 1);
  data[section][toStatus].push(item);
  saveData();
  
  renderList(section, fromStatus);
  renderList(section, toStatus);
}

function renderList(section, status) {
  const container = document.getElementById(`${section}-${status}-list`);
  const items = data[section][status];
  
  const tagMap = {
    current: 'now',
    completed: 'done',
    next: 'next'
  };
  const tagText = {
    current: section === 'games' ? 'PLAYING' : 'WATCHING',
    completed: 'DONE',
    next: 'NEXT'
  };
  const itemClass = `item-${status}`;
  
  const statusLabel = {
    current: section === 'games' ? 'Playing' : 'Watching',
    completed: 'Completed',
    next: 'Next'
  };
  
  container.innerHTML = items.map((item, i) => `
    <div class="list-item ${itemClass}" draggable="${checkAuth()}" data-section="${section}" data-status="${status}" data-index="${i}">
      <div class="item-num">${String(i + 1).padStart(2, '0')}</div>
      <div class="item-info ${item.url ? 'has-url' : ''}" ${item.url ? `onclick='openURL("${item.url}")'` : ''}>
        <div class="item-name">${item.name}</div>
        <div class="item-meta">${item.meta}</div>
      </div>
      <div class="item-actions">
        <select class="status-select" onchange="changeStatus('${section}', '${status}', ${i}, this.value)" onclick="event.stopPropagation()">
          <option value="current" ${status === 'current' ? 'selected' : ''}>${section === 'games' ? 'Playing' : 'Watching'}</option>
          <option value="completed" ${status === 'completed' ? 'selected' : ''}>Completed</option>
          <option value="next" ${status === 'next' ? 'selected' : ''}>Next</option>
        </select>
        <button class="item-btn" onclick="deleteItem('${section}', '${status}', ${i})" title="Delete">×</button>
      </div>
      <div class="item-tag tag-${tagMap[status]}">${tagText[status]}</div>
    </div>
  `).join('');
  
  setupDragAndDrop();
}

function openURL(url) {
  if (url && url.trim()) {
    window.open(url, '_blank');
  }
}

function setupDragAndDrop() {
  const isLoggedIn = checkAuth();
  if (!isLoggedIn) return; // Don't enable drag-and-drop for visitors
  
  const items = document.querySelectorAll('.list-item');
  
  items.forEach(item => {
    item.addEventListener('dragstart', (e) => {
      e.dataTransfer.effectAllowed = 'move';
      e.dataTransfer.setData('text/plain', JSON.stringify({
        section: item.dataset.section,
        status: item.dataset.status,
        index: parseInt(item.dataset.index)
      }));
      item.classList.add('dragging');
    });
    
    item.addEventListener('dragend', (e) => {
      item.classList.remove('dragging');
      items.forEach(i => i.classList.remove('drag-over'));
    });
    
    item.addEventListener('dragover', (e) => {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      item.classList.add('drag-over');
    });
    
    item.addEventListener('dragleave', (e) => {
      item.classList.remove('drag-over');
    });
    
    item.addEventListener('drop', (e) => {
      e.preventDefault();
      item.classList.remove('drag-over');
      
      const sourceData = JSON.parse(e.dataTransfer.getData('text/plain'));
      const targetSection = item.dataset.section;
      const targetStatus = item.dataset.status;
      
      if (sourceData.section === targetSection) {
        const itemData = data[sourceData.section][sourceData.status][sourceData.index];
        data[sourceData.section][sourceData.status].splice(sourceData.index, 1);
        data[targetSection][targetStatus].push(itemData);
        saveData();
        renderList(sourceData.section, sourceData.status);
        renderList(targetSection, targetStatus);
      }
    });
  });
}

function initApp() {
  checkAuth(); // Check authentication status on load
  ['games', 'anime'].forEach(section => {
    ['current', 'completed', 'next'].forEach(status => {
      renderList(section, status);
    });
  });
}

initApp();
</script>
</body>
</html>
